# cloud-api backend (Go service)
# Default is the production endpoint; override if running cloud-api locally.
CLOUD_API_URL=https://cloud-api.nan.builders
# Server-side only. Required for /api/waitlist to write to the backend.
CLOUD_API_WAITLIST_KEY=

# Resend (transactional email)
# Server-side only. Optional — if either RESEND_API_KEY or RESEND_FROM_EMAIL
# is missing, /api/waitlist still succeeds but skips the confirmation email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@nan.builders
