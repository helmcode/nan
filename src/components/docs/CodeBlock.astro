---
interface Props {
  code: string;
  language?: string;
}

const { code, language = 'text' } = Astro.props;

const langLabels: Record<string, string> = {
  js: 'JavaScript',
  ts: 'TypeScript',
  json: 'JSON',
  bash: 'Bash',
  curl: 'cURL',
  python: 'Python',
  py: 'Python',
  node: 'Node.js',
  nodejs: 'Node.js',
  openai: 'OpenAI SDK',
  opencode: 'OpenCode',
  openclaw: 'OpenClaw',
  zed: 'Zed',
  config: 'Config',
  text: 'Text',
};

const langLabel = langLabels[language] || language;
const uid = Math.random().toString(36).slice(2);
---

<div class="code-block rounded-xl border border-neutral-800/60 bg-[#0a0a0a] p-4 sm:p-5 mb-5 group" data-uid={uid} data-code={code}>
  <div class="flex items-center justify-between mb-3 px-1">
    <span class="font-mono text-[10px] text-violet-400/80 uppercase tracking-widest">{langLabel}</span>
    <button
      class="copy-btn flex items-center gap-1.5 rounded-md px-2 py-1 text-[10px] font-mono uppercase tracking-wider text-neutral-500 transition-colors hover:text-neutral-200 hover:bg-neutral-800/60"
      aria-label={`Copiar ${langLabel} código`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
      </svg>
      <span class="copy-label">Copiar</span>
    </button>
  </div>
  <pre class="whitespace-pre"><code>{code}</code></pre>
</div>
