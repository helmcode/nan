---
import { t } from '../../lib/i18n';

const { locale = 'en' } = Astro.props;
---

<div class="gradient-divider"></div>
<section id="privacy" class="px-6 py-24 md:py-32">
  <div class="max-w-3xl mx-auto">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('privacy.label', locale)}
    </p>

    <h2 class="font-mono text-2xl md:text-3xl text-white leading-snug tracking-tight mb-10">
      {t('privacy.heading', locale)}
    </h2>

    <div class="space-y-8 text-sm md:text-base text-neutral-300 leading-relaxed">
      <p>{t('privacy.p1', locale)}</p>
      <p>{t('privacy.p2', locale)}</p>
      <p>{t('privacy.p3', locale)}</p>

      <ul class="space-y-4 font-mono text-xs text-neutral-400">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
          <span>{t('privacy.points.noLogs', locale)}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
          <span>{t('privacy.points.localData', locale)}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
          <span>{t('privacy.points.euProcessing', locale)}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
          <span>{t('privacy.points.noTraining', locale)}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
          <span>{t('privacy.points.metrics', locale)}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
