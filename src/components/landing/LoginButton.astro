---
const locale = Astro.url.searchParams.get('lang') === 'en' ? 'en' : 'es';
const label = locale === 'en' ? 'Login' : 'Login';
---

<a
  href="https://cloud.nan.builders/"
  class="font-mono text-xs px-3 py-1.5 rounded-lg border border-neutral-800 text-neutral-400 hover:border-violet-500/40 hover:text-white transition-colors bg-[#0a0a0a]/80 backdrop-blur-sm"
>
  {label}
</a>
