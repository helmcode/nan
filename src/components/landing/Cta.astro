---
import { t } from '../../lib/i18n';
import WaitlistForm from './WaitlistForm.tsx';
import { getTranslations, getRegionLabels } from './waitlistForm.helpers';

const { locale = 'es' } = Astro.props;
const translations = getTranslations(locale);
const regionLabels = getRegionLabels(locale);
---

<div class="gradient-divider"></div>
<section id="waitlist" class="px-6 py-24 md:py-32">
  <div class="max-w-2xl mx-auto text-center">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('cta.label', locale)}
    </p>
    <h2 class="font-mono text-2xl md:text-3xl text-white tracking-tight leading-snug mb-5">
      {t('cta.heading', locale)}
    </h2>
    <p class="text-sm md:text-base text-neutral-300 leading-relaxed mb-12 max-w-lg mx-auto">
      {t('cta.description', locale)}
    </p>

    <div class="text-left">
      <WaitlistForm client:load t={translations} regionLabels={regionLabels} />
    </div>
  </div>
</section>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
