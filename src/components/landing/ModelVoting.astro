---
import { t, tArr } from '../../lib/i18n';

const { locale = 'en' } = Astro.props;

const rules = tArr('modelVoting.rules', locale);
---

<div class="gradient-divider"></div>
<section id="model-voting" class="px-6 py-24 md:py-32">
  <div class="max-w-3xl mx-auto">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('modelVoting.label', locale)}
    </p>

    <h2 class="font-mono text-2xl md:text-3xl text-white leading-snug tracking-tight mb-6">
      {t('modelVoting.heading', locale)}
    </h2>

    <ul class="space-y-3 text-sm md:text-base text-neutral-300 leading-relaxed">
      {
        rules.map((rule) => (
          <li class="flex items-start gap-3">
            <span class="mt-2 h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70" />
            <span>{rule}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
