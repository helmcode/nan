---
import { t } from '../../lib/i18n';

const { locale = 'en' } = Astro.props;
---

<div class="gradient-divider"></div>
<section id="about" class="px-6 py-24 md:py-32">
  <div class="max-w-2xl mx-auto">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('about.label', locale)}
    </p>

    <h2 class="font-mono text-xl md:text-2xl text-white leading-snug tracking-tight mb-8">
      {t('about.heading', locale)}
    </h2>

    <div class="space-y-4 text-sm md:text-base text-neutral-300 leading-relaxed">
      <p>{t('about.p1', locale)}</p>
      <p>{t('about.p2', locale)}</p>
      <p>{t('about.p3', locale)}</p>
      <p>{t('about.p4', locale)}</p>
    </div>
  </div>
</section>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
