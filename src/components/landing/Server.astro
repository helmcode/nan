---
import { t, tArr } from '../../lib/i18n';

const { locale = 'es' } = Astro.props;

const currentModels = [
  {
    name: 'deepseek-v4-flash',
    role: 'LLM · 284B-21B MoE · FP8 · 1M context · Tool calling · Reasoning · 100M tokens/mes',
    tag: 'llm',
  },
  {
    name: 'gemma4',
    role: 'LLM · 26B-A4B MoE · FP8 · 256K context · Tool calling · Reasoning · Vision',
    tag: 'llm',
  },
  {
    name: 'qwen3.6',
    role: 'LLM · 35B-A3B MoE · FP8 · 256K context · Tool calling · Reasoning',
    tag: 'llm',
  },
  {
    name: 'qwen3-embedding',
    role: 'Embeddings · 8B · 4096 dims · 100+ languages · MMTEB 70.58',
    tag: 'embedding',
  },
  {
    name: 'kokoro',
    role: 'TTS · 82M params · 67 voices · <1s latency · ef_dora · em_alex',
    tag: 'tts',
  },
  {
    name: 'whisper',
    role: 'STT · large-v3 · CTranslate2 · ~3.2% WER Spanish · auto language detection',
    tag: 'stt',
  },
];

const guarantees = tArr('server.guarantees', locale);
---

<div class="gradient-divider"></div>
<section id="server" class="px-6 py-24 md:py-32">
  <div class="max-w-5xl mx-auto">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('server.label', locale)}
    </p>

    <h2 class="font-mono text-2xl md:text-3xl text-white leading-snug tracking-tight mb-4">
      {t('server.heading', locale)}
    </h2>
    <p class="text-sm md:text-base text-neutral-300 leading-relaxed mb-14">
      {t('server.description', locale)}
    </p>

    <!-- Current models -->
    <p class="font-mono text-[10px] text-violet-400 uppercase tracking-widest mb-5">
      {t('server.models', locale)}
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-16">
      {
        currentModels.map((model) => (
          <div class="relative rounded-xl border border-dashed border-neutral-800 bg-neutral-900/20 p-6 transition-colors duration-300 hover:border-violet-500/30">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-mono text-base text-white">{model.name}</h3>
              <span class="font-mono text-[10px] uppercase tracking-wider text-violet-400/70 border border-violet-500/20 rounded-full px-2 py-0.5">
                {model.tag}
              </span>
            </div>
            <p class="text-xs text-neutral-400 leading-relaxed">{model.role}</p>
          </div>
        ))
      }
    </div>

    <!-- Guarantees -->
    <ul class="grid gap-3 sm:grid-cols-2 font-mono text-xs text-neutral-300">
      {
        guarantees.map((guarantee) => (
          <li class="flex items-start gap-3">
            <span class="mt-[3px] h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
            <span>{guarantee}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
