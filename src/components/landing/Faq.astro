---
import { t, tObj } from '../../lib/i18n';
import FaqAccordion from './FaqAccordion.tsx';

const { locale = 'es' } = Astro.props;

const itemsRaw = tObj<Record<string, { id: string; question: string; answer: string }>>('faq.items', locale);
const items = Object.values(itemsRaw);
---

<div class="gradient-divider"></div>
<section id="faq" class="px-6 py-24 md:py-32">
  <div class="max-w-3xl mx-auto">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('faq.label', locale)}
    </p>

    <h2 class="font-mono text-2xl md:text-3xl text-white leading-snug tracking-tight mb-10">
      {t('faq.heading', locale)}
    </h2>

    <FaqAccordion items={items} client:load />
  </div>
</section>

<footer class="border-t border-neutral-900 px-6 py-8">
  <div
    class="max-w-3xl mx-auto flex items-center justify-between text-xs text-neutral-500 font-mono"
  >
    <span>{t('footer.brand', locale)}</span>
    <span>&copy; {new Date().getFullYear()}</span>
  </div>
</footer>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
