---
import { t, tArr } from '../../lib/i18n';

const { locale = 'es' } = Astro.props;

const features = [0, 1, 2, 3, 4, 5].map((i) => ({
  name: t(`agents.features.items.${i}.name`, locale),
  desc: t(`agents.features.items.${i}.desc`, locale),
}));

const specs = [
  { label: 'CPU', value: t('agents.specs.cpu', locale) },
  { label: 'RAM', value: t('agents.specs.ram', locale) },
  { label: 'DISK', value: t('agents.specs.disk', locale) },
];

const stack = [
  { label: 'RUNTIME', value: t('agents.stack.runtime', locale) },
  { label: 'ORCHESTRATION', value: t('agents.stack.orchestration', locale) },
  { label: 'STORAGE', value: t('agents.stack.storage', locale) },
  { label: 'ISOLATION', value: t('agents.stack.isolation', locale) },
];

const guarantees = tArr('agents.guarantees', locale);
---

<div class="gradient-divider"></div>
<section id="agents" class="px-6 py-24 md:py-32">
  <div class="max-w-5xl mx-auto">
    <p class="font-mono text-xs text-violet-400 uppercase tracking-widest mb-6">
      {t('agents.label', locale)}
    </p>

    <h2 class="font-mono text-2xl md:text-3xl text-white leading-snug tracking-tight mb-4">
      {t('agents.heading', locale)}
    </h2>
    <p class="text-sm md:text-base text-neutral-300 leading-relaxed mb-14 max-w-3xl">
      {t('agents.description', locale)}
    </p>

    <!-- Specs + stack grid -->
    <div class="grid gap-6 md:grid-cols-2 mb-16">
      <div class="rounded-xl border border-neutral-800/60 bg-neutral-900/30 p-6">
        <p class="font-mono text-[10px] text-violet-400 uppercase tracking-widest mb-5">
          {t('agents.specs.label', locale)}
        </p>
        <dl class="space-y-3">
          {
            specs.map((spec) => (
              <div class="flex items-baseline justify-between gap-4 font-mono text-xs">
                <dt class="text-neutral-500 uppercase tracking-wider">
                  {spec.label}
                </dt>
                <dd class="text-neutral-200 text-right">{spec.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="rounded-xl border border-neutral-800/60 bg-neutral-900/30 p-6">
        <p class="font-mono text-[10px] text-violet-400 uppercase tracking-widest mb-5">
          {t('agents.stack.label', locale)}
        </p>
        <dl class="space-y-3">
          {
            stack.map((item) => (
              <div class="flex items-baseline justify-between gap-4 font-mono text-xs">
                <dt class="text-neutral-500 uppercase tracking-wider">
                  {item.label}
                </dt>
                <dd class="text-neutral-200 text-right">{item.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>

    <!-- Features grid -->
    <p class="font-mono text-[10px] text-violet-400 uppercase tracking-widest mb-5">
      {t('agents.features.label', locale)}
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-16">
      {
        features.map((feature) => (
          <div class="relative rounded-xl border border-dashed border-neutral-800 bg-neutral-900/20 p-6 transition-colors duration-300 hover:border-violet-500/30">
            <h3 class="font-mono text-base text-white mb-2">{feature.name}</h3>
            <p class="text-xs text-neutral-400 leading-relaxed">{feature.desc}</p>
          </div>
        ))
      }
    </div>

    <!-- Guarantees -->
    <ul class="grid gap-3 sm:grid-cols-2 font-mono text-xs text-neutral-300">
      {
        guarantees.map((guarantee) => (
          <li class="flex items-start gap-3">
            <span class="mt-[3px] h-[6px] w-[6px] shrink-0 rounded-full bg-violet-500/70 shadow-[0_0_8px_rgba(139,92,246,0.5)]" />
            <span>{guarantee}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gradient-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(139, 92, 246, 0.3) 30%,
      rgba(139, 92, 246, 0.3) 70%,
      transparent
    );
  }
</style>
