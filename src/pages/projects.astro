---
import Page from '../layouts/Page.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

interface Project {
  id: number;
  handle: string;
  name: string;
  description: string;
  imageUrl?: string;
  appUrl: string;
  repoUrl?: string;
  tags: string[];
  stars: number;
}

const safeUrl = (u?: string): string | null =>
  u && /^https?:\/\//i.test(u) ? u : null;

let projects: Project[] = [];
try {
  const base = env.CLOUD_API_URL.replace(/\/$/, '');
  const res = await fetch(`${base}/api/projects?limit=100`, {
    headers: { origin: 'https://nan.builders' },
  });
  if (res.ok) {
    const data = await res.json() as { projects: Project[] };
    projects = (data.projects ?? []).sort((a, b) => b.stars - a.stars);
  }
} catch {}

const featured = projects.slice(0, 5);
const rest = projects.slice(5);

const medalStyle: Record<number, { border: string; glow: string; badge: string; label: string }> = {
  0: {
    border: 'border-yellow-500/50',
    glow: 'shadow-[0_0_24px_rgba(234,179,8,0.12)]',
    badge: 'bg-yellow-500/20 text-yellow-300 border-yellow-500/40',
    label: '★ #1',
  },
  1: {
    border: 'border-slate-400/40',
    glow: 'shadow-[0_0_16px_rgba(148,163,184,0.08)]',
    badge: 'bg-slate-500/20 text-slate-300 border-slate-500/40',
    label: '★ #2',
  },
  2: {
    border: 'border-amber-700/50',
    glow: 'shadow-[0_0_16px_rgba(180,83,9,0.10)]',
    badge: 'bg-amber-700/20 text-amber-400 border-amber-700/40',
    label: '★ #3',
  },
  3: {
    border: 'border-violet-500/30',
    glow: '',
    badge: 'bg-violet-500/10 text-violet-400 border-violet-500/30',
    label: '★ #4',
  },
  4: {
    border: 'border-violet-500/20',
    glow: '',
    badge: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
    label: '★ #5',
  },
};
---

<Page
  title="Community Projects — nan.builders"
  description="Projects built by the NaN community. Discover what builders are shipping."
>
  <main class="min-h-screen px-6 pt-24 pb-32">
    <div class="mx-auto max-w-5xl">

      {/* Back nav */}
      <a
        href="/"
        class="inline-flex items-center gap-1.5 font-mono text-xs text-neutral-500 transition-colors hover:text-violet-400"
      >
        ← nan.builders
      </a>

      {/* Hero */}
      <div class="mt-10 mb-14">
        <div class="mb-3 inline-block rounded border border-violet-500/30 bg-violet-500/5 px-2.5 py-1 font-mono text-[10px] uppercase tracking-widest text-violet-400">
          Community
        </div>
        <h1 class="font-mono text-3xl font-bold text-white sm:text-4xl">
          Community Projects
        </h1>
        <p class="mt-3 max-w-xl font-mono text-sm leading-relaxed text-neutral-400">
          What the NaN community is building. Star your favourites on{' '}
          <a href="https://cloud.nan.builders/projects" class="text-violet-400 hover:text-violet-300 transition-colors">
            cloud.nan.builders
          </a>.
        </p>
      </div>

      {/* Featured top 5 */}
      {featured.length > 0 && (
        <section class="mb-16">
          <h2 class="mb-6 font-mono text-xs uppercase tracking-widest text-neutral-500">
            ★ Top Projects
          </h2>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((project, i) => {
              const medal = medalStyle[i] ?? medalStyle[4];
              const app = safeUrl(project.appUrl);
              const repo = safeUrl(project.repoUrl);
              return (
                <article
                  class={`flex flex-col overflow-hidden rounded-xl border bg-neutral-900/40 transition-all ${medal.border} ${medal.glow}`}
                >
                  {/* Image */}
                  <div class="relative aspect-video w-full overflow-hidden bg-neutral-900">
                    {safeUrl(project.imageUrl) ? (
                      <img
                        src={safeUrl(project.imageUrl)!}
                        alt={project.name}
                        loading={i < 3 ? 'eager' : 'lazy'}
                        decoding="async"
                        class="h-full w-full object-cover"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center text-neutral-700">
                        <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h3l2 2h9a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                        </svg>
                      </div>
                    )}
                    {/* Rank badge */}
                    <span
                      class={`absolute top-2 left-2 rounded border px-2 py-0.5 font-mono text-[10px] backdrop-blur-sm ${medal.badge}`}
                    >
                      {medal.label}
                    </span>
                    {/* Stars */}
                    <span class="absolute top-2 right-2 flex items-center gap-1 rounded bg-black/60 px-1.5 py-0.5 font-mono text-[10px] text-amber-300 backdrop-blur-sm">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                      {project.stars}
                    </span>
                  </div>

                  {/* Body */}
                  <div class="flex flex-1 flex-col gap-2 p-4">
                    <h3 class="font-mono text-sm font-semibold text-white leading-snug">
                      {project.name}
                    </h3>
                    <p class="font-mono text-[10px] text-neutral-500">by {project.handle}</p>
                    <p class="font-mono text-xs leading-relaxed text-neutral-400 line-clamp-3">
                      {project.description}
                    </p>

                    {project.tags.length > 0 && (
                      <div class="mt-1 flex flex-wrap gap-1">
                        {project.tags.map((tag) => (
                          <span class="rounded border border-neutral-800 px-1.5 py-0.5 font-mono text-[9px] text-neutral-500">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}

                    <div class="mt-auto flex items-center gap-4 pt-3">
                      {app && (
                        <a
                          href={app}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-xs text-violet-400 transition-colors hover:text-violet-300"
                        >
                          ↗ App
                        </a>
                      )}
                      {repo && (
                        <a
                          href={repo}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-xs text-neutral-500 transition-colors hover:text-white"
                        >
                          ↗ Repo
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      {/* Rest of projects */}
      {rest.length > 0 && (
        <section>
          <h2 class="mb-6 font-mono text-xs uppercase tracking-widest text-neutral-500">
            All Projects
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((project) => {
              const app = safeUrl(project.appUrl);
              const repo = safeUrl(project.repoUrl);
              return (
                <article class="flex flex-col overflow-hidden rounded-xl border border-neutral-800/60 bg-neutral-900/20 transition-colors hover:border-neutral-700/60">
                  {/* Image */}
                  <div class="relative aspect-video w-full overflow-hidden bg-neutral-900">
                    {safeUrl(project.imageUrl) ? (
                      <img
                        src={safeUrl(project.imageUrl)!}
                        alt={project.name}
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center text-neutral-800">
                        <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h3l2 2h9a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                        </svg>
                      </div>
                    )}
                    <span class="absolute top-2 right-2 flex items-center gap-1 rounded bg-black/60 px-1.5 py-0.5 font-mono text-[10px] text-neutral-400 backdrop-blur-sm">
                      <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                      {project.stars}
                    </span>
                  </div>

                  {/* Body */}
                  <div class="flex flex-1 flex-col gap-2 p-4">
                    <h3 class="font-mono text-sm font-medium text-white leading-snug">
                      {project.name}
                    </h3>
                    <p class="font-mono text-[10px] text-neutral-600">by {project.handle}</p>
                    <p class="font-mono text-xs leading-relaxed text-neutral-400 line-clamp-3">
                      {project.description}
                    </p>

                    {project.tags.length > 0 && (
                      <div class="mt-1 flex flex-wrap gap-1">
                        {project.tags.map((tag) => (
                          <span class="rounded border border-neutral-800 px-1.5 py-0.5 font-mono text-[9px] text-neutral-600">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}

                    <div class="mt-auto flex items-center gap-4 pt-3">
                      {app && (
                        <a
                          href={app}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-xs text-violet-400 transition-colors hover:text-violet-300"
                        >
                          ↗ App
                        </a>
                      )}
                      {repo && (
                        <a
                          href={repo}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-xs text-neutral-500 transition-colors hover:text-white"
                        >
                          ↗ Repo
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      {/* Empty state */}
      {projects.length === 0 && (
        <div class="rounded-xl border border-neutral-800/60 bg-neutral-900/20 p-16 text-center">
          <p class="font-mono text-sm text-neutral-500">No projects yet.</p>
          <p class="mt-2 font-mono text-xs text-neutral-600">
            Be the first to submit one on{' '}
            <a href="https://cloud.nan.builders/projects" class="text-violet-400 hover:text-violet-300 transition-colors">
              cloud.nan.builders
            </a>.
          </p>
        </div>
      )}

    </div>
  </main>
</Page>
