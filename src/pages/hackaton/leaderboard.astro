---
import Page from '../../layouts/Page.astro';
import { t } from '../../lib/i18n';
import { env } from 'cloudflare:workers';
export const prerender = false;
const locale = Astro.url.searchParams.get('lang') === 'en' ? 'en' : 'es';
const base = env.CLOUD_API_URL.replace(/\/$/, '');
let lb: any = { public: false, rows: [] };
try {
  const res = await fetch(`${base}/api/hackaton/leaderboard`, { headers: { origin: 'https://nan.builders' } });
  if (res.ok) lb = (await res.json())?.data ?? lb;
} catch {}
---
<Page title={`${t('hackaton.leaderboard.title', locale)} — nan.builders`}>
  <main class="px-6 pt-24 pb-32 mx-auto max-w-3xl">
    <h1 class="font-mono text-2xl text-white">{t('hackaton.leaderboard.title', locale)}</h1>
    {!lb.public ? (
      <p class="mt-6 text-neutral-400">{t('hackaton.leaderboard.hidden', locale)}</p>
    ) : (
      <table class="mt-6 w-full text-sm font-mono text-neutral-300">
        <thead class="text-[10px] uppercase tracking-widest text-violet-400">
          <tr><th class="text-left py-2">{t('hackaton.leaderboard.rank', locale)}</th>
              <th class="text-left">{t('hackaton.leaderboard.team', locale)}</th>
              <th class="text-right">{t('hackaton.leaderboard.votes', locale)}</th>
              <th class="text-right">{t('hackaton.leaderboard.auto', locale)}</th>
              <th class="text-right">{t('hackaton.leaderboard.total', locale)}</th></tr>
        </thead>
        <tbody>
          {lb.rows.map((r: any) => (
            <tr class="border-t border-neutral-800">
              <td class="py-2">{r.rank === 1 ? t('hackaton.leaderboard.winner', locale) : r.rank}</td>
              <td>{r.team_name}{r.not_prize_eligible ? ' *' : ''}</td>
              <td class="text-right">{r.votes}</td>
              <td class="text-right">{r.auto_points}</td>
              <td class="text-right text-white">{r.total}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </main>
</Page>
