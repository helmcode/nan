---
import Page from '../../layouts/Page.astro';
import CheckinForm from '../../components/hackaton/CheckinForm.tsx';
import { t, tObj } from '../../lib/i18n';

export const prerender = false;

const locale = Astro.url.searchParams.get('lang') === 'en' ? 'en' : 'es';
const hasSession = Astro.request.headers.get('cookie')?.includes('nan_session') ?? false;
const loginUrl = `/login?redirect=${encodeURIComponent('/hackaton/checkin')}`;
const pageTitle = `${t('hackaton.checkin.title', locale)} — nan.builders`;
---

<Page title={pageTitle}>
  <main class="px-6 pt-24 pb-32 mx-auto max-w-2xl">
    <a href="/hackaton" class="font-mono text-xs text-neutral-500 hover:text-violet-400">
      {t('hackaton.backToLanding', locale)}
    </a>
    <h1 class="mt-8 font-mono text-2xl text-white">{t('hackaton.checkin.title', locale)}</h1>
    <p class="mt-4 text-sm text-neutral-300">{t('hackaton.checkin.intro', locale)}</p>
    <div class="mt-8">
      {!hasSession ? (
        <a href={loginUrl} class="inline-block font-mono text-sm px-8 py-3 rounded-lg bg-violet-600 text-white hover:bg-violet-500">
          {t('hackaton.loginCta', locale)}
        </a>
      ) : (
        <CheckinForm client:load t={tObj('hackaton.checkin', locale)} />
      )}
    </div>
  </main>
</Page>
