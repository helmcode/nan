---
import Page from '../../layouts/Page.astro';
import VoteButton from '../../components/hackaton/VoteButton.tsx';
import { t, tObj } from '../../lib/i18n';
import { env } from 'cloudflare:workers';

export const prerender = false;

const locale = Astro.url.searchParams.get('lang') === 'en' ? 'en' : 'es';
const base = env.CLOUD_API_URL.replace(/\/$/, '');
let projects: any[] = [];
try {
  const res = await fetch(`${base}/api/hackaton/projects`, { headers: { origin: 'https://nan.builders' } });
  if (res.ok) projects = (await res.json())?.data ?? [];
} catch {}
---

<Page title={`${t('hackaton.projects.title', locale)} — nan.builders`}>
  <main class="px-6 pt-24 pb-32 mx-auto max-w-4xl">
    <a href="/hackaton" class="font-mono text-xs text-neutral-500 hover:text-violet-400">
      {t('hackaton.backToLanding', locale)}
    </a>
    <h1 class="mt-8 font-mono text-2xl text-white">{t('hackaton.projects.title', locale)}</h1>
    {projects.length === 0 ? (
      <p class="mt-8 text-sm text-neutral-400">{t('hackaton.projects.empty', locale)}</p>
    ) : (
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {projects.map((p) => (
          <article class="rounded-xl border border-neutral-800 bg-neutral-900/30 p-5">
            {p.media_url && <img src={p.media_url} alt="" class="mb-4 aspect-video w-full rounded-lg object-cover" loading="lazy" />}
            <h2 class="font-mono text-base text-white">{p.title}</h2>
            <p class="mt-1 font-mono text-xs text-violet-400">{p.team_name}</p>
            <p class="mt-3 text-sm text-neutral-300">{p.description}</p>
            <div class="mt-4 flex flex-wrap gap-3 font-mono text-xs">
              <a href={p.public_url} target="_blank" rel="noreferrer" class="text-violet-400 hover:text-violet-300">Live</a>
              <a href={p.space_url} target="_blank" rel="noreferrer" class="text-violet-400 hover:text-violet-300">Space</a>
              <a href={p.repo_url} target="_blank" rel="noreferrer" class="text-violet-400 hover:text-violet-300">Repo</a>
            </div>
            <div class="mt-5">
              <VoteButton client:load teamId={p.team_id} t={tObj('hackaton.projects', locale)} />
            </div>
          </article>
        ))}
      </div>
    )}
  </main>
</Page>
