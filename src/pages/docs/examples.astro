)

response = client.chat.completions.create(
  model="mimo-v2.5",
  messages=[{
    "role": "user",
    "content": [
      {"type": "text", "text": "Describe esta imagen."},
      {"type": "image_url", "image_url": {"url": "https://example.com/foto.jpg"}}
